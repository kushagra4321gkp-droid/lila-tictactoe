{
  "compilerOptions": {
    "target": "ES5",
    "strict": true,
    "esModuleInterop": true,
    "module": "ES2015",
    "moduleResolution": "node",
    "outDir": "./build",
    "noEmit": false,
    "skipLibCheck": true,
    "typeRoots": ["node_modules/@heroiclabs/nakama-runtime"],
    "lib": ["ES2015", "ES2016", "ES2017", "ES2018"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
